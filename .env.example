# Shared Foundry project endpoint (provided by instructor)
FOUNDRY_PROJECT_ENDPOINT=https://<shared-project>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL=gpt-4.1

# --- Observability (Section 5) ---
# Agent Framework uses ENABLE_CONSOLE_EXPORTERS, not the standard OTEL_*_EXPORTER vars.
# Comment out / remove these once you switch to Azure Monitor.
ENABLE_CONSOLE_EXPORTERS=true
ENABLE_SENSITIVE_DATA=true

# --- MCP (Section 7, optional) ---
# ATHORA_MCP_URL=https://policy-mcp.athora.example/mcp

# --- Optional: OpenAI fallback for offline experimentation ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL_ID=gpt-4o-mini
